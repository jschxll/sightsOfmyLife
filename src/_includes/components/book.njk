{% macro Book(title, author, key, value, isFirst) %}
    {% if isFirst %}
    <figure class="currentBook">
        <img id="cover-{{ title }}" loading="lazy">
        <figcaption class="book-desc">{{ title }} by {{ author }}</figcaption>
    </figure>
    {% else %}
    <figure class="book">
        <img id="cover-{{ title }}" loading="lazy">
        <figcaption class="book-desc">{{ title }} by {{ author }}</figcaption>
    </figure>
    {% endif %}

    <script>
        var key = "{{ key }}";
        var value = "{{ value }}";
        var isFirst = {{ isFirst }};
        var coverImg = document.getElementById("cover-{{ title }}");
        var size = "M";
        if (isFirst) {
            size = "L";
            coverImg.classList.add("current-book");
        }
        coverImg.src = `https://covers.openlibrary.org/b/${key}/${value}-${size}.jpg`;
    </script>
{% endmacro %}